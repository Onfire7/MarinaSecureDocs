# Per-marina environment (see docs: Stack & Architecture — Per-marina isolation).
# Copy to .env.local and fill in the values for this marina's deployment.

# The marina's InstantDB app id (InstantDB dashboard).
VITE_INSTANT_APP_ID=

# The marina's Clerk application publishable key. The Clerk application must
# have multi-session enabled (shared-device User Switch) and a JWT template
# registered on the InstantDB app so Instant trusts Clerk sessions.
VITE_CLERK_PUBLISHABLE_KEY=

# Name of the Clerk client configured on the InstantDB app (defaults to "clerk").
VITE_INSTANT_CLERK_CLIENT_NAME=clerk
